{
  "version": 2,
  "framework": "vite",
  "buildCommand": "pnpm -w run build:vercel",
  "outputDirectory": "artifacts/daycare-website/dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
