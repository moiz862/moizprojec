{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:vercel": "pnpm -r --if-present run build",
    "dev": "pnpm -r --parallel --filter @workspace/api-server --filter @workspace/daycare-website run dev",
    "start": "node ./artifacts/api-server/dist/index.mjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
